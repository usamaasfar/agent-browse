{
  "name": "@agent-browse/cli",
  "version": "0.2.0",
  "description": "CLI for agent-browse — web fetch and search via Ollama",
  "type": "module",
  "license": "MIT",
  "bin": {
    "agent-browse": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run index.ts",
    "build": "bun build ./index.ts --outfile dist/index.js --target bun",
    "build:binary": "bun build ./index.ts --compile --minify --bytecode --outfile dist/agent-browse"
  },
  "devDependencies": {
    "@agent-browse/core": "*",
    "@types/bun": "^1.3.9"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usamaasfar/agent-browse.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/usamaasfar/agent-browse#readme",
  "bugs": {
    "url": "https://github.com/usamaasfar/agent-browse/issues"
  },
  "keywords": [
    "browse",
    "agent",
    "ai",
    "web",
    "ollama",
    "cli"
  ]
}
